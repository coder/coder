# Ignore all packages from this repository by default
Package: *
Pin: origin download.docker.com
Pin-Priority: 1

# Docker Community Edition
# Pin to 27.x to remain compatible with containerd.io 1.7.23
# (Docker 28+ requires containerd.io >= 1.7.27)
Package: docker-ce
Pin: version 5:27.*
Pin-Priority: 500

# Docker command-line tool
Package: docker-ce-cli
Pin: version 5:27.*
Pin-Priority: 500

# containerd runtime
Package: containerd.io
Pin: origin download.docker.com
Pin-Priority: 500
