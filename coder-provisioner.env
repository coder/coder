# Required. The URL of the Coder deployment this provisioner will connect to,
# e.g. https://coder.example.com
CODER_URL=

# Authentication. Set ONE of the following. Scoped provisioner keys are
# strongly recommended; PSK is supported for backwards compatibility.
#
# Create a key with: coder provisioner keys create <name> --org <org>
CODER_PROVISIONER_DAEMON_KEY=
# CODER_PROVISIONER_DAEMON_PSK=

# Optional. Defaults to the machine hostname. Must be unique per provisioner.
# CODER_PROVISIONER_DAEMON_NAME=

# Optional. Comma-separated tags to filter which jobs this provisioner picks
# up. Ignored when authenticating with a provisioner key; the key's tags are
# used instead.
# CODER_PROVISIONERD_TAGS=environment=on_prem,datacenter=chicago

# Optional. Enable Prometheus metrics on the address below.
# CODER_PROMETHEUS_ENABLE=true
# CODER_PROMETHEUS_ADDRESS=127.0.0.1:2112

# Optional. Logging configuration.
# CODER_PROVISIONER_DAEMON_VERBOSE=false
# CODER_PROVISIONER_DAEMON_LOGGING_HUMAN=/dev/stderr
# CODER_PROVISIONER_DAEMON_LOGGING_JSON=
# CODER_PROVISIONER_DAEMON_LOGGING_STACKDRIVER=

# Run "coder provisioner start --help" for the full flag list.
