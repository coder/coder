{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"useTabs": true,
	"tabWidth": 2,
	"printWidth": 80,
	"singleQuote": false,
	"jsxSingleQuote": false,
	"quoteProps": "as-needed",
	"trailingComma": "all",
	"semi": true,
	"arrowParens": "always",
	"bracketSameLine": false,
	"bracketSpacing": true,
	"ignorePatterns": [
		"**/node_modules/**",
		"**/pnpm-lock.yaml",
		"**/static/*.html",
		"e2e/**/*Generated.ts",
		"scripts/*.mjs",
		"storybook-static/**"
	]
}
