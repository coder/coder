#!/usr/bin/env bash
#
# Pre-push hook that runs the same lite checks as pre-commit
# (gen, fmt, lint, typos, build) to catch issues before they
# reach CI.
#
# The full test suite is intentionally omitted here; it runs
# in CI after pushing.
#
# To run the full suite locally, use: make pre-push
#
# Installation (worktree-compatible):
#
#   git config core.hooksPath scripts/githooks
#
# Bypass: git push --no-verify

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"
unset GIT_DIR

# In linked worktrees, set worktree-scoped hooksPath to override shared config.
if [[ "$(git rev-parse --git-dir)" != "$(git rev-parse --git-common-dir)" ]]; then
	git config --worktree core.hooksPath scripts/githooks
fi
exec make pre-commit
